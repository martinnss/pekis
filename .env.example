// Copy this file to `.env` and replace the values with identifiers you control.
// This file intentionally uses Xcode build-settings syntax so the project can read it directly.

PEKIS_DEVELOPMENT_TEAM = YOURTEAMID
PEKIS_BUNDLE_IDENTIFIER = com.yourname.pekis
PEKIS_CLOUDKIT_CONTAINER_ID = iCloud.com.yourname.pekis
// Optional: legacy CloudKit containers to keep in your entitlements alongside the primary one.
// Set these to your primary container if you only have one, or leave them matching
// PEKIS_CLOUDKIT_CONTAINER_ID. New contributors can safely set both to the same value as above.
PEKIS_CLOUDKIT_CONTAINER_LEGACY_A = iCloud.com.yourname.pekis
PEKIS_CLOUDKIT_CONTAINER_LEGACY_B = iCloud.com.yourname.pekis
PEKIS_DEBUG_APS_ENVIRONMENT = development
PEKIS_RELEASE_APS_ENVIRONMENT = production
